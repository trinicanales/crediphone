# ============================================================
# CREDIPHONE — Variables de Entorno
# Copiar este archivo como .env.local y rellenar los valores
# ============================================================

# ---- SUPABASE (requerido) ----
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ---- URL Base de la App (requerido) ----
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- FASE 20: Payjoy Integration (opcional) ----
PAYJOY_ENABLED=false
PAYJOY_API_KEY=
PAYJOY_BASE_URL=https://partner.payjoy.com/v1
PAYJOY_WEBHOOK_SECRET=
PAYJOY_AUTO_SYNC=false
PAYJOY_PRICING_URL=https://payjoy.com/admin-console/api/default-pricing

# ---- FASE 28: Web Push / VAPID Keys (para notificaciones push nativas) ----
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@tudominio.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # mismo valor que VAPID_PUBLIC_KEY

# ---- FASE 28: Secreto para API routes internas ----
INTERNAL_API_SECRET=cambia_este_secreto_en_produccion
